# Django CRM Environment Variables - PRODUCTION TEMPLATE
# DO NOT commit this file to version control
# Copy to .env on production server (Render)

# =============================================================================
# PRODUCTION SETTINGS (Render/Supabase)
# =============================================================================
SECRET_KEY=your-production-secret-key-generate-new-one
DEBUG=False
ALLOWED_HOSTS=django-crm-fdqz.onrender.com

# PostgreSQL via Supabase (Production)
# Get this from Supabase Dashboard → Settings → Database → Connection string
# Use the Pooler connection string (port 6543) if available
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Email (optional - configure for production)
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
