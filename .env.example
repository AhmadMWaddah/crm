# Django CRM Environment Variables Template
# Copy this file to .env and fill in your actual values
# This file IS safe to commit to version control

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Generate a unique secret key for production!
# Command: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite:///db.sqlite3

# Production: Supabase PostgreSQL (FREE)
# =====================================================
# How to get your Supabase DATABASE_URL:
# 
# 1. Go to https://supabase.com
# 2. Select your project
# 3. Go to Settings → Database
# 4. Enable "Connection pooling" (Transaction mode)
# 5. Copy the "Pooler connection string"
# 6. Replace [YOUR-PASSWORD] with your actual password
#
# Format (Pooler - RECOMMENDED):
# postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
#
# Example:
# DATABASE_URL=postgresql://postgres.abcdefghijk:MyStr0ngP@ss@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# ⚠️ IMPORTANT:
# - Use the POOLER connection string (port 6543), NOT direct connection (port 5432)
# - The pooler hostname ends with ".pooler.supabase.com"
# - Include ?sslmode=require at the end
# - Remove any spaces in the password

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
