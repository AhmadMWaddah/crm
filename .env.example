# Django CRM Environment Variables Template
# Copy this file to .env and fill in your actual values
# This file IS safe to commit to version control

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Generate a unique secret key for production!
# Command: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite:///db.sqlite3

# Production: PostgreSQL (PythonAnywhere/Render)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# PythonAnywhere Example:
# DATABASE_URL=postgresql://yourusername$crm-db:yourpassword@epg-01.rackdc.com/yourusername$crm-db
# Render Example:
# DATABASE_URL=postgresql://user:password@hostname:5432/database_name

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
