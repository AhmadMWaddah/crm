# Django CRM Environment Variables Template
# Copy this file to .env and fill in your actual values
# This file IS safe to commit to version control

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Generate a unique secret key for production!
# Command: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite:///db.sqlite3

# Production: Neon PostgreSQL (FREE)
# Format: postgresql://username:password@hostname/dbname?sslmode=require
# Example (replace with YOUR actual credentials from Neon Dashboard):
# DATABASE_URL=postgresql://neondb_owner:npg_xxx@ep-round-pine-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ⚠️ IMPORTANT: Remove any spaces in the password!
# ❌ WRONG: npg_tBcq7Nf0KVWA 
# ✅ CORRECT: npg_tBcq7Nf0KVWA

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
