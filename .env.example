# Django CRM Environment Variables Template
# Copy this file to .env and fill in your actual values
# This file IS safe to commit to version control

# SECURITY WARNING: Generate a unique secret key for production!
# You can generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# SECURITY WARNING: Set to False in production!
DEBUG=True

# Comma-separated list of allowed hosts (e.g., localhost,127.0.0.1,yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database configuration (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3

# Email configuration (optional - for later phases)
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
