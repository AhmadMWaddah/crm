# Django CRM - Environment Variables Template
# Copy this file to .env and configure for your environment

# =============================================================================
# FOR LOCAL DEVELOPMENT (Copy this section to .env)
# =============================================================================
SECRET_KEY=django-insecure-your-local-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite for local development (no database setup needed)
DATABASE_URL=sqlite:///db.sqlite3

# =============================================================================
# FOR PRODUCTION DEPLOYMENT ON RENDER (Use .env.production template)
# =============================================================================
# SECRET_KEY=<generate-strong-random-key>
# DEBUG=False
# ALLOWED_HOSTS=your-app-name.onrender.com
# DATABASE_URL=postgresql://postgres:password@host:port/database?sslmode=require
#
# Get DATABASE_URL from Supabase Dashboard → Settings → Database → Connection string
# Use Pooler connection if available (port 6543) for better performance
